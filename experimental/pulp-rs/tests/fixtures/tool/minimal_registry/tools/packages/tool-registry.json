{
  "schema_version": 1,
  "tools": {
    "uv": {
      "display_name": "UV",
      "category": "binary",
      "description": "Fast Python package manager",
      "license": "MIT",
      "install_method": "binary_download",
      "pinned_version": "0.4.27",
      "managed_by_pulp": true,
      "binary_sources": {
        "macOS-arm64": {
          "url_template": "https://example.com/${version}/uv.tar.gz",
          "archive_format": "tar.gz",
          "binary_name": "uv"
        },
        "macOS-x64": {
          "url_template": "https://example.com/${version}/uv.tar.gz",
          "archive_format": "tar.gz",
          "binary_name": "uv"
        },
        "Linux-x64": {
          "url_template": "https://example.com/${version}/uv.tar.gz",
          "archive_format": "tar.gz",
          "binary_name": "uv"
        },
        "Linux-arm64": {
          "url_template": "https://example.com/${version}/uv.tar.gz",
          "archive_format": "tar.gz",
          "binary_name": "uv"
        },
        "Windows-x64": {
          "url_template": "https://example.com/${version}/uv.zip",
          "archive_format": "zip",
          "binary_name": "uv.exe"
        }
      }
    },
    "clap-validator": {
      "display_name": "CLAP Validator",
      "category": "binary",
      "description": "Validate CLAP plugins",
      "license": "ISC",
      "install_method": "binary_download",
      "pinned_version": "0.3.0",
      "managed_by_pulp": true,
      "binary_sources": {
        "macOS-arm64": {
          "url_template": "https://example.com/${version}/clap-validator.tar.gz",
          "archive_format": "tar.gz",
          "binary_name": "clap-validator"
        }
      }
    },
    "video-proof": {
      "display_name": "Video Proof",
      "category": "developer_tool",
      "description": "Optional desktop validation video proof tooling",
      "license": "MIT",
      "install_method": "npm_package",
      "npm_package_root": "tools/local-ci",
      "npm_default_script": "smoke-video-proof",
      "pinned_version": "0.0.0",
      "managed_by_pulp": true,
      "install_scope": "machine",
      "distribution_lane": "tool_addon",
      "package_format": "not_pulp_add",
      "artifact_status": "source_tree_iteration",
      "artifact_policy": "Keep Remotion outside shipped artifacts.",
      "artifact_pack_command": "python3 tools/local-ci/pack_video_proof_tool.py --json",
      "artifact_pack_npm_script": "npm --prefix tools/local-ci run pack-video-proof-tool -- --json",
      "artifact_verify_command": "python3 tools/local-ci/pack_video_proof_tool.py --verify <manifest> --json",
      "artifact_manifest_schema": "pulp.video-proof-tool-package.v1"
    }
  }
}
