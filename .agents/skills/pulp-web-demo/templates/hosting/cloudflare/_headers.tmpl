# Cross-origin isolation for WCLAP — GENERATED by pulp-web-demo v{{GENERATOR_VERSION}} (owned file).
# CRITICAL: these patterns MUST cover the deployed base path ({{BASE_PATH}}), not just "/".
# The threaded .wasm imports a shared WebAssembly.Memory, which requires crossOriginIsolated.
{{BASE_PATH}}*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin

# Worklet/wasm assets served under the base path also need a resource policy so a
# cross-origin-isolated document may embed them.
{{BASE_PATH}}*.wasm
  Cross-Origin-Resource-Policy: same-origin
{{BASE_PATH}}*.js
  Cross-Origin-Resource-Policy: same-origin
